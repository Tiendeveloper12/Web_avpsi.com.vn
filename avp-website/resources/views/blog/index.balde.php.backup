<!DOCTYPE html>
<html>
<head>
    <title>Blog & Articles</title>
    <style>
        body { font-family: Arial; margin: 20px; background: #f5f5f5; }
        .container { max-width: 900px; margin: 0 auto; }
        h1 { color: #333; }
        .articles { display: grid; gap: 20px; }
        .article-card { 
            background: white; 
            padding: 20px; 
            border-radius: 5px; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border-left: 4px solid #007bff;
        }
        .article-card h2 { margin-top: 0; }
        .article-card p { color: #666; line-height: 1.6; }
        .article-card a { 
            color: #007bff; 
            text-decoration: none; 
            font-weight: bold;
        }
        .article-card a:hover { text-decoration: underline; }
        .date { color: #999; font-size: 0.9em; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Blog & Articles</h1>

        <div class="articles">
            @foreach($articles as $article)
                <div class="article-card">
                    <h2>{{ $article->title }}</h2>
                    <p class="date">Posted on: {{ $article->created_at }}</p>
                    <p>{{ Str::limit($article->description, 150) }}</p>
                    <a href="/blog/{{ $article->id }}">Read More →</a>
                </div>
            @endforeach
        </div>
    </div>
</body>
</html>