<!DOCTYPE html>
<html>
<head>
    <title>Gallery</title>
    <style>
        body { font-family: Arial; margin: 20px; background: #f5f5f5; }
        .container { max-width: 1000px; margin: 0 auto; }
        h1 { color: #333; }
        .galleries { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .gallery-card { 
            background: white; 
            border-radius: 5px; 
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }
        .gallery-card:hover { transform: translateY(-5px); }
        .gallery-card img { width: 100%; height: 200px; object-fit: cover; }
        .gallery-card-content { padding: 15px; }
        .gallery-card h3 { margin: 0 0 10px 0; }
        .gallery-card p { color: #666; font-size: 0.9em; margin: 0; }
        .gallery-card a { 
            display: inline-block; 
            margin-top: 10px;
            color: #007bff; 
            text-decoration: none; 
            font-weight: bold;
        }
        .gallery-card a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Gallery</h1>

        <div class="galleries">
            @foreach($galleries as $gallery)
                <div class="gallery-card">
                    @if(isset($gallery->image) && $gallery->image)
                        <img src="/images/{{ $gallery->image }}" alt="{{ $gallery->title }}">
                    @else
                        <div style="width: 100%; height: 200px; background: #ddd; display: flex; align-items: center; justify-content: center;">
                            <span style="color: #999;">No Image</span>
                        </div>
                    @endif
                    <div class="gallery-card-content">
                        <h3>{{ $gallery->title }}</h3>
                        <p>{{ Str::limit($gallery->description, 80) }}</p>
                        <a href="/gallery/{{ $gallery->id }}">View Gallery →</a>
                    </div>
                </div>
            @endforeach
        </div>
    </div>
</body>
</html>